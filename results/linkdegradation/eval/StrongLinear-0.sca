par LinkDegradation.configurator addSubnetRoutes true
par LinkDegradation.configurator addDirectRoutes true
par LinkDegradation.configurator optimizeRoutes true
par LinkDegradation.configurator dumpTopology false
par LinkDegradation.configurator dumpLinks false
par LinkDegradation.configurator dumpAddresses false
par LinkDegradation.configurator dumpRoutes false
par LinkDegradation.configurator dumpConfig "\"\""
par LinkDegradation.scenarioManager typename "\"inet.common.scenario.ScenarioManager\""
par LinkDegradation.scenarioManager script "<script>...</script> at content:1"
par LinkDegradation.degradationController typename "\"dissertationsim.controller.LinkDegradationController\""
par LinkDegradation.degradationController firstInterfaceModule "\"^.r2.eth[1]\""
par LinkDegradation.degradationController secondInterfaceModule "\"^.r3.eth[0]\""
