par LinkDegradation.hostB.at typename "\"inet.common.MessageDispatcher\""
par LinkDegradation.hostB.at displayStringTextFormat "\"processed %p pk (%l)\""
par LinkDegradation.hostB.at forwardServiceRegistration true
par LinkDegradation.hostB.at forwardProtocolRegistration true
par LinkDegradation.hostB typename "\"inet.node.inet.StandardHost\""
par LinkDegradation.hostB hasStatus false
par LinkDegradation.hostB osgModel "\"\""
par LinkDegradation.hostB osgModelColor "\"\""
par LinkDegradation.hostB canvasImage "\"\""
par LinkDegradation.hostB canvasImageColor "\"\""
par LinkDegradation.hostB recordPcap false
par LinkDegradation.hostB numPcapRecorders 0
par LinkDegradation.hostB numLoInterfaces 1
par LinkDegradation.hostB numWlanInterfaces 0
par LinkDegradation.hostB numEthInterfaces 0
par LinkDegradation.hostB numPppInterfaces 0
par LinkDegradation.hostB numTunInterfaces 0
par LinkDegradation.hostB numVirtInterfaces 0
par LinkDegradation.hostB fcsMode "\"declared\""
attr enum declared,computed
par LinkDegradation.hostB hasIpv4 true
par LinkDegradation.hostB hasIpv6 false
par LinkDegradation.hostB hasGn false
par LinkDegradation.hostB forwarding false
par LinkDegradation.hostB multicastForwarding false
par LinkDegradation.hostB hasUdp true
par LinkDegradation.hostB hasTcp true
par LinkDegradation.hostB hasSctp false
par LinkDegradation.hostB numApps 2
