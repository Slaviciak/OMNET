config **.hostB.app[1].typename UdpSink
config **.hostB.app[1].localPort 5001
config **.degradationController.firstInterfaceModule "\"^.r2.eth[1]\""
config **.degradationController.secondInterfaceModule "\"^.r3.eth[0]\""
config **.degradationController.startTime 20s
config **.degradationController.endTime 40s
config **.degradationController.updateInterval 0.5s
config **.degradationController.profile "\"mildLinear\""
config **.degradationController.targetDelay 15ms
config **.degradationController.targetPacketErrorRate 0.03
config **.scenarioManager.script "xml(         \"<script>\\n\" +         \"<at t='45s'><disconnect src-module='r2' src-gate='ethg$o[1]'/></at>\\n\" +         \"<at t='45s'><disconnect src-module='r3' src-gate='ethg$o[0]'/></at>\\n\" +         \"</script>\")"
