config image-path ../../../inet4.5/images
config description "Overall upward delay and PER trend with deterministic oscillations on r2-r3 before hard failure at 45s"
config **.degradationController.profile "\"unstableLinear\""
config **.degradationController.targetDelay 25ms
config **.degradationController.targetPacketErrorRate 0.05
config network dissertationsim.simulations.linkdegradation.LinkDegradation
config sim-time-limit 60s
config output-scalar-file ../../results/linkdegradation/eval/UnstableLinear-0.sca
config output-vector-file ../../results/linkdegradation/eval/UnstableLinear-0.vec
config eventlog-file ../../results/linkdegradation/debug/UnstableLinear-0.elog
config record-eventlog false
config **.ospf.ospfConfig "xmldoc(\"ASConfig.xml\")"
config **.hostA.numApps 2
config **.hostB.numApps 2
config **.hostA.app[0].typename UdpBasicApp
config **.hostA.app[0].destAddresses "\"hostB\""
config **.hostA.app[0].destPort 5000
config **.hostA.app[0].messageLength 512B
