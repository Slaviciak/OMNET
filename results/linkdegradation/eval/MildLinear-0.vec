config image-path ../../../inet4.5/images
config description "Moderate linear delay and PER increase on r2-r3 from 20s to 40s, followed by hard failure at 45s"
config network dissertationsim.simulations.linkdegradation.LinkDegradation
config sim-time-limit 60s
config output-scalar-file ../../results/linkdegradation/eval/MildLinear-0.sca
config output-vector-file ../../results/linkdegradation/eval/MildLinear-0.vec
config eventlog-file ../../results/linkdegradation/debug/MildLinear-0.elog
config record-eventlog false
config **.ospf.ospfConfig "xmldoc(\"ASConfig.xml\")"
config **.hostA.numApps 2
config **.hostB.numApps 2
config **.hostA.app[0].typename UdpBasicApp
config **.hostA.app[0].destAddresses "\"hostB\""
config **.hostA.app[0].destPort 5000
config **.hostA.app[0].messageLength 512B
config **.hostA.app[0].sendInterval 1s
config **.hostA.app[0].startTime 10s
config **.hostA.app[1].typename UdpBasicApp
config **.hostA.app[1].destAddresses "\"hostB\""
config **.hostA.app[1].destPort 5001
config **.hostA.app[1].messageLength 128B
config **.hostA.app[1].sendInterval 250ms
config **.hostA.app[1].startTime 12s
config **.hostB.app[0].typename UdpSink
config **.hostB.app[0].localPort 5000
config **.hostB.app[1].typename UdpSink
config **.hostB.app[1].localPort 5001
config **.degradationController.firstInterfaceModule "\"^.r2.eth[1]\""
config **.degradationController.secondInterfaceModule "\"^.r3.eth[0]\""
config **.degradationController.startTime 20s
config **.degradationController.endTime 40s
config **.degradationController.updateInterval 0.5s
config **.degradationController.profile "\"mildLinear\""
config **.degradationController.targetDelay 15ms
config **.degradationController.targetPacketErrorRate 0.03
config **.scenarioManager.script "xml(         \"<script>\\n\" +         \"<at t='45s'><disconnect src-module='r2' src-gate='ethg$o[1]'/></at>\\n\" +         \"<at t='45s'><disconnect src-module='r3' src-gate='ethg$o[0]'/></at>\\n\" +         \"</script>\")"
